rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 允許所有人讀取圖片
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // 允許上傳圖片到 backgrounds 和 stamps 資料夾
    match /backgrounds/{imageId} {
      allow write: if request.resource.size < 5 * 1024 * 1024  // 5MB
                   && request.resource.contentType.matches('image/.*');
    }
    
    match /stamps/{imageId} {
      allow write: if request.resource.size < 2 * 1024 * 1024  // 2MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
